# Copy this file to .env and fill in real values.
# .env is loaded automatically by app.py via python-dotenv.
# NEVER commit your actual .env file — add it to .gitignore.

# --- Session / auth ---
# Random secret used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=replace_with_a_long_random_value

# Set to "true" once you're serving over HTTPS so the session cookie is
# only ever sent over an encrypted connection. Keep "false" for local http.
COOKIE_SECURE=false

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/

# --- LangSmith ---
# Get an API key from https://smith.langchain.com/ -> Settings -> API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__replace_with_your_key
LANGCHAIN_PROJECT=ollamachat
# Optional — only needed for self-hosted LangSmith instances
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Copy this file to .env and fill in real values.
# .env is loaded automatically by app.py via python-dotenv.
# NEVER commit your actual .env file — add it to .gitignore.

# --- Session / auth ---
# Random secret used to sign session cookies. Generate one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET_KEY=9f7f4d1c0e5a8b2d6c3f1a7e4b8d9c2e1f3a6b7c8d0e2f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2c3d4e5f6

# Set to "true" once you're serving over HTTPS so the session cookie is
# only ever sent over an encrypted connection. Keep "false" for local http.
COOKIE_SECURE=false

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017/

# --- LangSmith ---
# Get an API key from https://smith.langchain.com/ -> Settings -> API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=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
LANGCHAIN_PROJECT=ollamachat
# Optional — only needed for self-hosted LangSmith instances
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
